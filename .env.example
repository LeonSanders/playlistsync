# Copy to .env and fill in — never commit .env

SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=https://your-app.railway.app/auth/spotify/callback

TIDAL_CLIENT_ID=your_tidal_client_id
# No Tidal client secret — uses PKCE
TIDAL_REDIRECT_URI=https://your-app.railway.app/auth/tidal/callback

# Your deployed app URL (no trailing slash)
APP_URL=https://your-app.railway.app
