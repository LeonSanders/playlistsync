# Copy this to .env and fill in your credentials
# Never commit .env to git

SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://localhost/auth/spotify/callback

TIDAL_CLIENT_ID=your_tidal_client_id_here
TIDAL_CLIENT_SECRET=your_tidal_client_secret_here
TIDAL_REDIRECT_URI=http://localhost/auth/tidal/callback

# Set to your server's public URL in production
FRONTEND_URL=http://localhost
