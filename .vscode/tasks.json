{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-backend",
      "command": "dotnet",
      "type": "process",
      "args": ["build", "${workspaceFolder}/backend/PlaylistSync.csproj", "/property:GenerateFullPaths=true", "/consoleloggerparameters:NoSummary", "--configuration", "Debug"],
      "problemMatcher": "$msCompile",
      "group": "build",
      "presentation": {
        "reveal": "silent",
        "close": true
      }
    },
    {
      "label": "build-tests",
      "command": "dotnet",
      "type": "process",
      "args": ["build", "${workspaceFolder}/backend.tests/PlaylistSync.Tests.csproj", "/property:GenerateFullPaths=true", "/consoleloggerparameters:NoSummary"],
      "problemMatcher": "$msCompile",
      "group": "build",
      "presentation": {
        "reveal": "silent",
        "close": true
      }
    },
    {
      "label": "watch-backend",
      "command": "dotnet",
      "type": "process",
      "args": ["watch", "run", "--project", "${workspaceFolder}/backend/PlaylistSync.csproj"],
      "problemMatcher": "$msCompile",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "run-tests",
      "command": "dotnet",
      "type": "process",
      "args": ["test", "${workspaceFolder}/backend.tests/PlaylistSync.Tests.csproj", "--logger", "console;verbosity=normal"],
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "run-tests-watch",
      "command": "dotnet",
      "type": "process",
      "args": ["watch", "test", "--project", "${workspaceFolder}/backend.tests/PlaylistSync.Tests.csproj"],
      "problemMatcher": "$msCompile",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "docker-up",
      "type": "shell",
      "command": "docker compose up --build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "docker-down",
      "type": "shell",
      "command": "docker compose down",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "close": true
      }
    },
    {
      "label": "db-migrate",
      "command": "dotnet",
      "type": "process",
      "args": ["ef", "database", "update", "--project", "${workspaceFolder}/backend/PlaylistSync.csproj"],
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "always",
        "close": false
      }
    }
  ]
}
