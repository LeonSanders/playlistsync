{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend (ASP.NET Core)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-backend",
      "program": "${workspaceFolder}/backend/bin/Debug/net8.0/PlaylistSync.dll",
      "args": [],
      "cwd": "${workspaceFolder}/backend",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5000"
      },
      "sourceFileMap": {
        "/Views": "${workspaceFolder}/backend/Views"
      }
    },
    {
      "name": "Frontend (Vite)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/frontend",
      "console": "integratedTerminal",
      "serverReadyAction": {
        "pattern": "Local:.+(http://localhost:[0-9]+)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    },
    {
      "name": "Tests (xUnit)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-tests",
      "program": "${workspaceFolder}/backend.tests/bin/Debug/net8.0/PlaylistSync.Tests.dll",
      "args": [],
      "cwd": "${workspaceFolder}/backend.tests",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Test"
      }
    },
    {
      "name": "Attach to Backend",
      "type": "coreclr",
      "request": "attach",
      "processId": "${command:pickProcess}"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack",
      "configurations": ["Backend (ASP.NET Core)", "Frontend (Vite)"],
      "stopAll": true
    }
  ]
}
