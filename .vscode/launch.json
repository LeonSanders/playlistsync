{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend (ASP.NET Core)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-backend",
      "program": "${workspaceFolder}/backend/bin/Debug/net10.0/PlaylistSync.dll",
      "args": [],
      "cwd": "${workspaceFolder}/backend",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5001",
        "DOTNET_ENVIRONMENT": "Development"
      },
      "sourceFileMap": {
        "/Views": "${workspaceFolder}/backend/Views"
      }
    },
    {
      "name": "Frontend (Vite)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev"
      ],
      "cwd": "${workspaceFolder}/frontend",
      "console": "integratedTerminal",
      "serverReadyAction": {
        "pattern": "Local:.+(http://localhost:[0-9]+)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    },
    {
      "name": "Tests (xUnit)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-tests",
      "program": "${workspaceFolder}/backend.tests/bin/Debug/net10.0/PlaylistSync.Tests.dll",
      "args": [],
      "cwd": "${workspaceFolder}/backend.tests",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Test"
      }
    },
    {
      "name": "Attach to Backend (local process)",
      "type": "coreclr",
      "request": "attach",
      "processId": "${command:pickProcess}"
    },
    {
      "name": "Attach to Backend (Docker)",
      "type": "coreclr",
      "request": "attach",
      "processId": "${command:pickRemoteProcess}",
      "pipeTransport": {
        "pipeProgram": "docker",
        "pipeArgs": [
          "exec",
          "-i",
          "playlistsync-backend-1"
        ],
        "debuggerPath": "/vsdbg/vsdbg",
        "pipeCwd": "${workspaceFolder}"
      },
      "sourceFileMap": {
        "/src": "${workspaceFolder}/backend"
      },
      "justMyCode": false
    }
  ],
  "compounds": [
    {
      "name": "Full Stack (local)",
      "configurations": [
        "Backend (ASP.NET Core)",
        "Frontend (Vite)"
      ],
      "stopAll": true
    },
    {
      "name": "Full Stack (Docker debug)",
      "configurations": [
        "Attach to Backend (Docker)",
        "Frontend (Vite)"
      ],
      "stopAll": true
    }
  ]
}