{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Docker: Attach .NET Core",
            "type": "docker",
            "request": "launch",
            "preLaunchTask": "compose-up", // Optional: runs docker-compose up first
            "netCore": {
                "appProject": "${workspaceFolder}/backend/PlaylistSync.csproj"
            },
            "containerName": "backend_service_name"
        },
        {
            "name": "Docker: Attach React",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:3000",
            "webRoot": "${workspaceFolder}/ClientApp/src",
            "sourceMapPathOverrides": {
                "webpack:///src/*": "${webRoot}/*"
            }
        }
    ],
    "compounds": [
        {
            "name": "Docker-Compose: Full Stack",
            "configurations": [
                "Docker: Attach .NET Core",
                "Docker: Attach React"
            ]
        }
    ]
}